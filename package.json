{
  "name": "chathub-replica",
  "version": "1.1.1",
  "description": "Aggregate mainstream AI chat platforms into one panel — a fully functional replica of Simple Chat Hub.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:priority": "node scripts/build-priority.mjs",
    "build:pdf-worker": "node scripts/copy-pdf-worker.mjs",
    "build": "npm run build:priority && npm run build:pdf-worker && tsc -b --noEmit && vite build",
    "build:firefox": "node scripts/build-firefox.mjs",
    "pack": "node scripts/pack.mjs chrome",
    "pack:firefox": "node scripts/pack.mjs firefox",
    "pack:all": "node scripts/pack.mjs all",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "antd": "^5.21.5",
    "classnames": "^2.5.1",
    "i18next": "^23.16.4",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.1",
    "uuid": "^11.0.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.28",
    "@types/chrome": "^0.0.279",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "crx3": "^2.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
